{
  "scopeName": "source.abel",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.abel",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.abel",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.abel",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.abel",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.abel",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.abel",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.abel",
          "match": "\\b(if|elseif|else|while|for|repeat|do|break|continue|return)\\b"
        },
        {
          "name": "keyword.declaration.abel",
          "match": "\\b(module|use|export|fn|struct|backend|enum|type|init|operator|debt|public|private|const)\\b"
        },
        {
          "name": "keyword.operator.abel",
          "match": "(\\|>|\\.\\.|\\.\\.\\.|::|->|==|!=|<=|>=|<\\?|>\\?|\\*\\*)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.abel",
          "match": "\\b(void|bool|int|long|i64|f64|char|str|any|vector|func)\\b"
        },
        {
          "name": "constant.language.abel",
          "match": "\\b(true|false|nullptr)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.abel",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.abel",
          "match": "\\b(?<=fn\\s)(?:[A-Za-z_][A-Za-z0-9_]*\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.function.abel"
            }
          }
        }
      ]
    }
  }
}
