{
  "name": "abel-vscode",
  "displayName": "Abel",
  "description": "VSCode language support for Abel via abel-lsp.",
  "version": "0.1.0",
  "publisher": "abel",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:abel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "abel",
        "aliases": [
          "Abel",
          "abel"
        ],
        "extensions": [
          ".abel"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "abel",
        "scopeName": "source.abel",
        "path": "./syntaxes/abel.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "abel",
        "scopes": {
          "keyword": [
            "keyword.control.abel",
            "keyword.declaration.abel"
          ],
          "type": [
            "entity.name.type.abel",
            "storage.type.abel"
          ],
          "function": [
            "entity.name.function.abel"
          ],
          "variable": [
            "variable.other.readwrite.abel"
          ],
          "property": [
            "variable.other.property.abel"
          ],
          "string": [
            "string.quoted.double.abel"
          ],
          "number": [
            "constant.numeric.abel"
          ],
          "operator": [
            "keyword.operator.abel"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[abel]": {
        "editor.semanticHighlighting.enabled": true
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "variable:abel": "#9CDCFE",
          "property:abel": "#9CDCFE",
          "function:abel": "#DCDCAA",
          "type:abel": "#4EC9B0",
          "keyword:abel": "#C586C0",
          "operator:abel": "#D4D4D4",
          "number:abel": "#B5CEA8",
          "string:abel": "#CE9178"
        }
      }
    },
    "configuration": {
      "title": "Abel",
      "properties": {
        "abel.lsp.path": {
          "type": "string",
          "default": "abel-lsp",
          "description": "Path to the abel-lsp executable."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
