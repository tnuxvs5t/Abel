file(WRITE "${alias_project_dir}/abel.package.json" [=[
{
  "name": "cli-multifile-project-alias",
  "version": "0.1.0",
  "entry": "src/main.abel",
  "backendArtifacts": [
    {
      "backendId": "MathSystem",
      "path": "@CMAKE_BINARY_DIR@/plugins/libmath_backend.so",
      "symbols": ["fast_add"]
    }
  ]
}
]=])

file(WRITE "${alias_project_dir}/src/lib/a.abel" [=[
module cli.lib.a;

fn int value() {
    return 10;
}

struct Point {
    int x;
}
]=])

file(WRITE "${alias_project_dir}/src/lib/math.abel" [=[
module cli.lib.math;

backend MathSystem {
    fn int fast_add(int a, int b);
}
]=])

file(WRITE "${alias_project_dir}/src/main.abel" [=[
module cli.main;
use cli.lib.a as A;
use cli.lib.math as M;

fn int main() {
    A::Point p = A::Point(29);
    return A::value() + p.x + M::MathSystem::fast_add(1, 2);
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${alias_project_dir}"
    RESULT_VARIABLE alias_check_result
    OUTPUT_VARIABLE alias_check_stdout
    ERROR_VARIABLE alias_check_stderr
)
