use cli.lib.b;

fn int main() {
    Point p = Point(40);
    return p.x + 2;
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${ambiguous_struct_project_dir}"
    RESULT_VARIABLE ambiguous_struct_check_result
    OUTPUT_VARIABLE ambiguous_struct_check_stdout
    ERROR_VARIABLE ambiguous_struct_check_stderr
)
if(ambiguous_struct_check_result EQUAL 0)
    message(FATAL_ERROR "abel check unexpectedly accepted ambiguous unqualified imported struct:\n${ambiguous_struct_check_stdout}\n${ambiguous_struct_check_stderr}")
endif()
string(FIND "${ambiguous_struct_check_stderr}" "struct 'Point' is ambiguous across imported modules" ambiguous_struct_pos)
if(ambiguous_struct_pos EQUAL -1)
    message(FATAL_ERROR "abel check did not explain ambiguous imported struct:\n${ambiguous_struct_check_stdout}\n${ambiguous_struct_check_stderr}")
endif()
string(FIND "${ambiguous_struct_check_stderr}" "candidate structs" ambiguous_struct_candidates_pos)
if(ambiguous_struct_candidates_pos EQUAL -1)
    message(FATAL_ERROR "abel check did not list ambiguous struct candidates:\n${ambiguous_struct_check_stdout}\n${ambiguous_struct_check_stderr}")
endif()
string(FIND "${ambiguous_struct_check_stderr}" "cli.lib.a::Point" ambiguous_struct_candidate_a_pos)
string(FIND "${ambiguous_struct_check_stderr}" "cli.lib.b::Point" ambiguous_struct_candidate_b_pos)
if(ambiguous_struct_candidate_a_pos EQUAL -1 OR ambiguous_struct_candidate_b_pos EQUAL -1)
    message(FATAL_ERROR "abel check did not name both ambiguous struct candidates:\n${ambiguous_struct_check_stdout}\n${ambiguous_struct_check_stderr}")
endif()
string(FIND "${ambiguous_struct_check_stderr}" "related:" ambiguous_struct_related_pos)
if(ambiguous_struct_related_pos EQUAL -1)
    message(FATAL_ERROR "abel check did not print related spans for ambiguous struct:\n${ambiguous_struct_check_stdout}\n${ambiguous_struct_check_stderr}")
endif()

