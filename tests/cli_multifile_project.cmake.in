}
]=])

file(WRITE "${qualified_no_use_project_dir}/src/main.abel" [=[
module cli.main;

fn int main() {
    return cli.lib.a::value() + 2;
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${qualified_no_use_project_dir}"
    RESULT_VARIABLE qualified_no_use_check_result
    OUTPUT_VARIABLE qualified_no_use_check_stdout
    ERROR_VARIABLE qualified_no_use_check_stderr
)
if(qualified_no_use_check_result EQUAL 0)
    message(FATAL_ERROR "abel check unexpectedly accepted qualified same-package call without use:\n${qualified_no_use_check_stdout}\n${qualified_no_use_check_stderr}")
