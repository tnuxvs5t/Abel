    message(FATAL_ERROR "abel test --report-json did not record zero failures:\n${filter_report_text}")
endif()
string(FIND "${filter_report_text}" "\"path\": \"tests/pass_alpha.abel\"" filter_report_path_pos)
if(filter_report_path_pos EQUAL -1)
    message(FATAL_ERROR "abel test --report-json did not record matching test path:\n${filter_report_text}")
endif()
string(FIND "${filter_report_text}" "fail_beta" filter_report_skip_pos)
if(NOT filter_report_skip_pos EQUAL -1)
    message(FATAL_ERROR "abel test --report-json included non-matching filtered test:\n${filter_report_text}")
endif()

