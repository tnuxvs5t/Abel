}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${qualified_backend_no_use_project_dir}"
    RESULT_VARIABLE qualified_backend_no_use_check_result
    OUTPUT_VARIABLE qualified_backend_no_use_check_stdout
    ERROR_VARIABLE qualified_backend_no_use_check_stderr
)
if(qualified_backend_no_use_check_result EQUAL 0)
    message(FATAL_ERROR "abel check unexpectedly accepted qualified backend call without use:\n${qualified_backend_no_use_check_stdout}\n${qualified_backend_no_use_check_stderr}")
endif()
string(FIND "${qualified_backend_no_use_check_stderr}" "backend 'MathSystem' is not visible from current module" qualified_backend_no_use_not_visible_pos)
if(qualified_backend_no_use_not_visible_pos EQUAL -1)
    message(FATAL_ERROR "abel check did not explain missing use for qualified backend call:\n${qualified_backend_no_use_check_stdout}\n${qualified_backend_no_use_check_stderr}")
