set(qualified_struct_project_dir "@CMAKE_BINARY_DIR@/cli-multifile-project-qualified-struct")
file(REMOVE_RECURSE "${qualified_struct_project_dir}")
file(MAKE_DIRECTORY "${qualified_struct_project_dir}/src/lib")

file(WRITE "${qualified_struct_project_dir}/abel.package.json" [=[
{
  "name": "cli-multifile-project-qualified-struct",
  "version": "0.1.0",
  "entry": "src/main.abel"
}
]=])

file(WRITE "${qualified_struct_project_dir}/src/lib/a.abel" [=[
module cli.lib.a;

struct Point {
    int x;
}
]=])

file(WRITE "${qualified_struct_project_dir}/src/lib/b.abel" [=[
module cli.lib.b;

struct Point {
    int x;
}
]=])

file(WRITE "${qualified_struct_project_dir}/src/main.abel" [=[
module cli.main;
use cli.lib.a;
use cli.lib.b;

fn int main() {
    cli.lib.a::Point pa = cli.lib.a::Point(10);
    cli.lib.b::Point pb = cli.lib.b::Point(30);
    return pa.x + pb.x + 2;
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${qualified_struct_project_dir}"
    RESULT_VARIABLE qualified_struct_check_result
    OUTPUT_VARIABLE qualified_struct_check_stdout
    ERROR_VARIABLE qualified_struct_check_stderr
)
if(NOT qualified_struct_check_result EQUAL 0)
    message(FATAL_ERROR "abel check rejected qualified module struct type/constructor:\n${qualified_struct_check_stdout}\n${qualified_struct_check_stderr}")
endif()

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" run "${qualified_struct_project_dir}"
    RESULT_VARIABLE qualified_struct_run_result
    OUTPUT_VARIABLE qualified_struct_run_stdout
    ERROR_VARIABLE qualified_struct_run_stderr
)
if(NOT qualified_struct_run_result EQUAL 42)
    message(FATAL_ERROR "abel run expected qualified struct project exit code 42, got ${qualified_struct_run_result}:\n${qualified_struct_run_stdout}\n${qualified_struct_run_stderr}")
