    COMMAND "@CMAKE_BINARY_DIR@/abel" run "${alias_project_dir}"
    RESULT_VARIABLE alias_run_result
    OUTPUT_VARIABLE alias_run_stdout
    ERROR_VARIABLE alias_run_stderr
)
