set(ABEL_BIN "@ABEL_SDK_TEST_INSTALL_PREFIX@/@CMAKE_INSTALL_BINDIR@/abel")
set(PROJECT_DIR "@CMAKE_BINARY_DIR@/sdk-package-fixture")
set(PLUGIN_PATH "@ABEL_SDK_TEST_BUILD_DIR@/plugins/libsdk_fixture_backend.so")
set(EXPECTED_CACHE "${PROJECT_DIR}/.abel/cache/backend/sdk-app/SdkSystem/libsdk_fixture_backend.so")

if (NOT EXISTS "${ABEL_BIN}")
    message(FATAL_ERROR "installed abel CLI does not exist: ${ABEL_BIN}")
endif()

if (NOT EXISTS "${PLUGIN_PATH}")
    message(FATAL_ERROR "SDK fixture plugin does not exist: ${PLUGIN_PATH}")
endif()

file(REMOVE_RECURSE "${PROJECT_DIR}")
file(MAKE_DIRECTORY "${PROJECT_DIR}/src")

file(WRITE "${PROJECT_DIR}/abel.package.json" [=[
{
  "name": "sdk-app",
  "version": "0.1.0",
  "entry": "src/main.abel",
  "backendArtifacts": [
    {
      "backendId": "SdkSystem",
      "path": "]=] "${PLUGIN_PATH}" [=[",
      "symbols": [
        "add",
        "letters",
        "sum_i64",
        "guard",
        "join",
        "count",
        "call_int",
        "map_create",
        "map_len",
        "map_contains",
        "map_set",
        "map_get",
        "dynamic_map"
      ]
    }
  ]
}
]=])

file(WRITE "${PROJECT_DIR}/src/main.abel" [=[
backend SdkSystem {
    fn int add(int a, int b);
    fn vector<char> letters();
    fn long sum_i64(vector<long> xs);
    fn int guard(int x);
    fn str join(any... args);
    fn int count(any... args);
    fn any call_int(any f, int x);
    fn long map_create();
    fn int map_len(long h);
    fn bool map_contains(long h, any key);
    fn void map_set(long h, any key, any value);
    fn any map_get(long h, any key);
    fn any dynamic_map();
}

fn int inc(int x) {
    return x + 1;
}

fn int main() {
    vector<char> cs = SdkSystem::letters();
    vector<long> xs = {1, 2, 3};
    str joined = SdkSystem::join("S", 4, false);
    int joined_bonus = 0;
    if (joined == "S4false") {
        joined_bonus = 7;
    } else {
        joined_bonus = 100;
    }
    long h = SdkSystem::map_create();
    SdkSystem::map_set(h, "answer", 4);
    vector<any> compound = {"k", true};
    SdkSystem::map_set(h, compound, "ok");
    int map_bonus = 0;
    if (SdkSystem::map_contains(h, "answer")
        && SdkSystem::map_len(h) == 2
        && cast<int>(SdkSystem::map_get(h, "answer")) == 4
        && cast<str>(SdkSystem::map_get(h, compound)) == "ok") {
        map_bonus = 11;
    } else {
        map_bonus = 100;
    }
    any f = inc;
    any da = 2;
    any db = 3;
    any dm = SdkSystem::dynamic_map();
    dm["bonus"] = 10;
    int dynamic_bonus = 0;
    if (cast<int>(dm["bonus"]) == 10
        && dm == dm
        && any_is(dm, "dynamic:sdk.dynamic_map")
        && any_debug(dm) == "<sdk.dynamic_map>") {
        dynamic_bonus = 10;
    } else {
        dynamic_bonus = 100;
    }
    any row = [{"name" = "Nitori", "score" = 39}];
    any pair = row |> [[_["name"], _["score"] + 3]];
    row |> (_["score"] = cast<int>(_["score"]) + 3);
    int hydraulic_bonus = 0;
    if (cast<str>(pair[0]) == "Nitori"
        && cast<int>(pair[1]) == 42
        && cast<int>(row["score"]) == 42
        && any_is(row, "dynamic:strmap")
        && any_is(pair, "dynamic:tuple")
        && SdkSystem::count(row, pair, "water") == 3) {
        hydraulic_bonus = 17;
    } else {
        hydraulic_bonus = 100;
    }
    return SdkSystem::add(cs.len(), cast<int>(SdkSystem::sum_i64(xs)))
        + SdkSystem::guard(0)
        + joined_bonus
        + SdkSystem::count("S", 4, false)
        + map_bonus
        + cast<int>(SdkSystem::call_int(f, 40))
        + cast<int>(da + db)
        + dynamic_bonus
        + hydraulic_bonus;
}
]=])

execute_process(
    COMMAND "${ABEL_BIN}" build "${PROJECT_DIR}"
    RESULT_VARIABLE build_result
    OUTPUT_VARIABLE build_output
    ERROR_VARIABLE build_error
)
if (NOT build_result EQUAL 0)
    message(FATAL_ERROR "installed abel build failed:\n${build_output}\n${build_error}")
endif()

if (NOT EXISTS "${EXPECTED_CACHE}")
    message(FATAL_ERROR "abel build did not cache SDK fixture backend at ${EXPECTED_CACHE}")
endif()

execute_process(
    COMMAND "${ABEL_BIN}" run "${PROJECT_DIR}"
    RESULT_VARIABLE run_result
    OUTPUT_VARIABLE run_output
    ERROR_VARIABLE run_error
)
if (NOT run_result EQUAL 102)
    message(FATAL_ERROR "installed abel run expected exit 102, got ${run_result}:\n${run_output}\n${run_error}")
endif()

file(WRITE "${PROJECT_DIR}/src/main.abel" [=[
backend SdkSystem {
    fn any dynamic_map();
}

fn int main() {
    any dm = SdkSystem::dynamic_map();
    any missing = dm["missing"];
    return cast<int>(missing);
}
]=])

execute_process(
    COMMAND "${ABEL_BIN}" run "${PROJECT_DIR}"
    RESULT_VARIABLE bad_dynamic_result
    OUTPUT_VARIABLE bad_dynamic_output
    ERROR_VARIABLE bad_dynamic_error
)
if (bad_dynamic_result EQUAL 0)
    message(FATAL_ERROR "installed abel run unexpectedly accepted bad dynamic object access:\n${bad_dynamic_output}\n${bad_dynamic_error}")
endif()
string(FIND "${bad_dynamic_error}" "sdk.dynamic_map missing key 'missing'" missing_key_pos)
if (missing_key_pos EQUAL -1)
    message(FATAL_ERROR "installed SDK fixture did not report dynamic object missing-key diagnostic:\n${bad_dynamic_output}\n${bad_dynamic_error}")
endif()
