set(project_root "@CMAKE_BINARY_DIR@/cli-dependency-sources")
set(dep_dir "${project_root}/dep")
set(app_dir "${project_root}/app")
file(REMOVE_RECURSE "${project_root}")
file(MAKE_DIRECTORY "${dep_dir}/src/lib")
file(MAKE_DIRECTORY "${app_dir}/src")

file(WRITE "${dep_dir}/abel.package.json" [=[
{
  "name": "dep",
  "version": "0.1.0",
  "entry": "src/main.abel"
}
]=])

file(WRITE "${dep_dir}/src/main.abel" [=[
module dep.main;

fn int main() {
    return 0;
}
]=])

file(WRITE "${dep_dir}/src/lib/math.abel" [=[
module dep.lib.math;

struct Box {
    int value;
}

export struct PublicBox {
    int value;
}

backend HiddenSystem {
    fn int secret();
}

fn int private_value() {
    return 40;
}

fn int private_box_value(Box b) {
    return b.value;
}

export fn int dep_value() {
    Box b = Box(1);
    return private_value() + private_box_value(b);
}

export fn int public_box_value(PublicBox b) {
    return b.value;
}
]=])

file(WRITE "${dep_dir}/src/lib/api.abel" [=[
module dep.api;
export use dep.lib.math;
]=])

file(WRITE "${dep_dir}/src/lib/private_api.abel" [=[
module dep.private_api;
use dep.lib.math;
]=])

file(WRITE "${app_dir}/abel.package.json" [=[
{
  "name": "app",
  "version": "0.1.0",
  "entry": "src/main.abel",
  "dependencies": [
    {"name": "dep", "kind": "path", "path": "../dep"}
  ]
}
]=])

file(WRITE "${app_dir}/src/main.abel" [=[
module app.main;
use dep.lib.math;

struct Box {
    int value;
}

fn int private_value() {
    return 1;
}

fn int main() {
    Box b = Box(1);
    PublicBox p = PublicBox(2);
    return dep_value() + public_box_value(p) - b.value;
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${app_dir}"
    RESULT_VARIABLE check_result
    OUTPUT_VARIABLE check_stdout
    ERROR_VARIABLE check_stderr
)
if(NOT check_result EQUAL 0)
    message(FATAL_ERROR "abel check failed:\n${check_stdout}\n${check_stderr}")
endif()

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" run "${app_dir}"
    RESULT_VARIABLE run_result
    OUTPUT_VARIABLE run_stdout
    ERROR_VARIABLE run_stderr
)
if(NOT run_result EQUAL 42)
    message(FATAL_ERROR "abel run expected exit code 42, got ${run_result}:\n${run_stdout}\n${run_stderr}")
endif()

set(reexport_app_dir "${project_root}/reexport-app")
file(MAKE_DIRECTORY "${reexport_app_dir}/src")
file(WRITE "${reexport_app_dir}/abel.package.json" [=[
{
  "name": "reexport-app",
  "version": "0.1.0",
  "entry": "src/main.abel",
  "dependencies": [
    {"name": "dep", "kind": "path", "path": "../dep"}
  ]
}
]=])

file(WRITE "${reexport_app_dir}/src/main.abel" [=[
module reexport.main;
use dep.api;

fn int main() {
    PublicBox p = PublicBox(2);
    return dep_value() + public_box_value(p) - 1;
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${reexport_app_dir}"
    RESULT_VARIABLE reexport_check_result
    OUTPUT_VARIABLE reexport_check_stdout
    ERROR_VARIABLE reexport_check_stderr
)
if(NOT reexport_check_result EQUAL 0)
    message(FATAL_ERROR "abel check rejected dependency re-export:\n${reexport_check_stdout}\n${reexport_check_stderr}")
endif()

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" run "${reexport_app_dir}"
    RESULT_VARIABLE reexport_run_result
    OUTPUT_VARIABLE reexport_run_stdout
    ERROR_VARIABLE reexport_run_stderr
)
if(NOT reexport_run_result EQUAL 42)
    message(FATAL_ERROR "abel run expected re-export app exit code 42, got ${reexport_run_result}:\n${reexport_run_stdout}\n${reexport_run_stderr}")
endif()

set(non_reexport_app_dir "${project_root}/non-reexport-app")
file(MAKE_DIRECTORY "${non_reexport_app_dir}/src")
file(WRITE "${non_reexport_app_dir}/abel.package.json" [=[
{
  "name": "non-reexport-app",
  "version": "0.1.0",
  "entry": "src/main.abel",
  "dependencies": [
    {"name": "dep", "kind": "path", "path": "../dep"}
  ]
}
]=])

file(WRITE "${non_reexport_app_dir}/src/main.abel" [=[
module non_reexport.main;
use dep.private_api;

fn int main() {
    return dep_value();
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${non_reexport_app_dir}"
    RESULT_VARIABLE non_reexport_check_result
    OUTPUT_VARIABLE non_reexport_check_stdout
    ERROR_VARIABLE non_reexport_check_stderr
)
if(non_reexport_check_result EQUAL 0)
    message(FATAL_ERROR "abel check unexpectedly accepted non-exported use propagation:\n${non_reexport_check_stdout}\n${non_reexport_check_stderr}")
endif()
string(FIND "${non_reexport_check_stderr}" "not visible from current module" non_reexport_not_visible_pos)
if(non_reexport_not_visible_pos EQUAL -1)
    message(FATAL_ERROR "abel check did not reject non-exported use propagation clearly:\n${non_reexport_check_stdout}\n${non_reexport_check_stderr}")
endif()

set(bad_app_dir "${project_root}/bad-app")
file(MAKE_DIRECTORY "${bad_app_dir}/src")
file(WRITE "${bad_app_dir}/abel.package.json" [=[
{
  "name": "bad-app",
  "version": "0.1.0",
  "entry": "src/main.abel",
  "dependencies": [
    {"name": "dep", "kind": "path", "path": "../dep"}
  ]
}
]=])

file(WRITE "${bad_app_dir}/src/main.abel" [=[
module bad.main;
use dep.lib.math;

fn int main() {
    return private_value();
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${bad_app_dir}"
    RESULT_VARIABLE bad_check_result
    OUTPUT_VARIABLE bad_check_stdout
    ERROR_VARIABLE bad_check_stderr
)
if(bad_check_result EQUAL 0)
    message(FATAL_ERROR "abel check unexpectedly accepted dependency private function:\n${bad_check_stdout}\n${bad_check_stderr}")
endif()
string(FIND "${bad_check_stderr}" "not exported" not_exported_pos)
if(not_exported_pos EQUAL -1)
    message(FATAL_ERROR "abel check did not explain export failure:\n${bad_check_stdout}\n${bad_check_stderr}")
endif()

set(bad_struct_dir "${project_root}/bad-struct-app")
file(MAKE_DIRECTORY "${bad_struct_dir}/src")
file(WRITE "${bad_struct_dir}/abel.package.json" [=[
{
  "name": "bad-struct-app",
  "version": "0.1.0",
  "entry": "src/main.abel",
  "dependencies": [
    {"name": "dep", "kind": "path", "path": "../dep"}
  ]
}
]=])

file(WRITE "${bad_struct_dir}/src/main.abel" [=[
module bad.struct_case;
use dep.lib.math;

fn int main() {
    Box b = Box(1);
    return b.value;
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${bad_struct_dir}"
    RESULT_VARIABLE bad_struct_check_result
    OUTPUT_VARIABLE bad_struct_check_stdout
    ERROR_VARIABLE bad_struct_check_stderr
)
if(bad_struct_check_result EQUAL 0)
    message(FATAL_ERROR "abel check unexpectedly accepted dependency private struct:\n${bad_struct_check_stdout}\n${bad_struct_check_stderr}")
endif()
string(FIND "${bad_struct_check_stderr}" "struct 'Box' from dependency package 'dep' is not exported" struct_not_exported_pos)
if(struct_not_exported_pos EQUAL -1)
    message(FATAL_ERROR "abel check did not explain private struct export failure:\n${bad_struct_check_stdout}\n${bad_struct_check_stderr}")
endif()

set(bad_backend_dir "${project_root}/bad-backend-app")
file(MAKE_DIRECTORY "${bad_backend_dir}/src")
file(WRITE "${bad_backend_dir}/abel.package.json" [=[
{
  "name": "bad-backend-app",
  "version": "0.1.0",
  "entry": "src/main.abel",
  "dependencies": [
    {"name": "dep", "kind": "path", "path": "../dep"}
  ]
}
]=])

file(WRITE "${bad_backend_dir}/src/main.abel" [=[
module bad.backend_case;
use dep.lib.math;

fn int main() {
    return HiddenSystem::secret();
}
]=])

execute_process(
    COMMAND "@CMAKE_BINARY_DIR@/abel" check "${bad_backend_dir}"
    RESULT_VARIABLE bad_backend_check_result
    OUTPUT_VARIABLE bad_backend_check_stdout
    ERROR_VARIABLE bad_backend_check_stderr
)
if(bad_backend_check_result EQUAL 0)
    message(FATAL_ERROR "abel check unexpectedly accepted dependency private backend:\n${bad_backend_check_stdout}\n${bad_backend_check_stderr}")
endif()
string(FIND "${bad_backend_check_stderr}" "backend 'HiddenSystem' from dependency package 'dep' is not exported" backend_not_exported_pos)
if(backend_not_exported_pos EQUAL -1)
    message(FATAL_ERROR "abel check did not explain private backend export failure:\n${bad_backend_check_stdout}\n${bad_backend_check_stderr}")
endif()
